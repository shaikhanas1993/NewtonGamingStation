# Angular major versions often land before the wider tooling ecosystem
# (ng-bootstrap, @testing-library/angular, jest-preset-angular) publishes peer
# ranges that explicitly name the new Angular major. npm 7+ then aborts install
# with "unable to resolve dependency tree".
#
# legacy-peer-deps tells npm to install anyway (the npm 6 behaviour). These tools
# work fine against the newer Angular at runtime; only the declared peer metadata
# lags behind.
legacy-peer-deps=true
